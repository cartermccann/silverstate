{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "statusCode": 301
    },

    { "source": "/programs/teen-lgbtqia", "destination": "/programs/lgbtqia-affirming-care", "statusCode": 301 },
    { "source": "/programs/teen-holistic-treatment", "destination": "/programs/holistic-treatment", "statusCode": 301 },
    { "source": "/programs/teen-trauma-informed-care", "destination": "/programs/trauma-informed-care", "statusCode": 301 },
    { "source": "/programs/teen-medication-treatment", "destination": "/programs/medication-management", "statusCode": 301 },
    { "source": "/programs/teen-crisis-prevention-intervention-cpi", "destination": "/programs/crisis-prevention-intervention", "statusCode": 301 },
    { "source": "/programs/teen-therapy-programs", "destination": "/programs/therapy-programs", "statusCode": 301 },
    { "source": "/programs/silver-state-youth-academy", "destination": "/about/youth-academy", "statusCode": 301 },
    { "source": "/programs/teen-residential-treatment", "destination": "/programs/residential-treatment", "statusCode": 301 },
    { "source": "/programs/teen-meditation-therapy", "destination": "/programs/meditation-mindfulness", "statusCode": 301 },
    { "source": "/programs/teen-individual-therapy", "destination": "/programs/individual-therapy", "statusCode": 301 },
    { "source": "/programs/teen-group-therapy", "destination": "/programs/group-therapy", "statusCode": 301 },
    { "source": "/programs/teen-personalized-treatment-plan", "destination": "/our-approach", "statusCode": 301 },
    { "source": "/programs/teen-family-therapy", "destination": "/programs/family-therapy", "statusCode": 301 },
    { "source": "/programs/teen-cognitive-behavioral-therapy", "destination": "/programs/cbt", "statusCode": 301 },

    { "source": "/what-we-treat/teen-anxiety", "destination": "/conditions/anxiety-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-depression", "destination": "/conditions/depression-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-mental-health", "destination": "/conditions", "statusCode": 301 },
    { "source": "/what-we-treat/teen-ocd-treatment", "destination": "/conditions/ocd-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-substance-abuse", "destination": "/conditions/substance-abuse-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-suicidal-ideation", "destination": "/conditions/suicidal-ideation-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-trauma", "destination": "/conditions/trauma-ptsd-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-bpd-treatment", "destination": "/conditions/bpd-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-conduct-disorder-cd-treatment", "destination": "/conditions/conduct-disorder-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-dual-diagnosis", "destination": "/conditions/dual-diagnosis-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-eating-disorder-treatment/teen-arfid", "destination": "/conditions/arfid-treatment", "statusCode": 301 },
    { "source": "/what-we-treat/teen-eating-disorder-treatment", "destination": "/conditions", "statusCode": 301 },
    { "source": "/what-we-treat/teen-autism-spectrum-disorder-asd", "destination": "/conditions/autism-spectrum-treatment", "statusCode": 301 },

    { "source": "/insurances-we-accept", "destination": "/insurance", "statusCode": 301 },
    { "source": "/about-us", "destination": "/about/our-team", "statusCode": 301 },
    { "source": "/contact-us", "destination": "/contact", "statusCode": 301 },
    { "source": "/blog", "destination": "/resources", "statusCode": 301 },

    { "source": "/crisis-prevention-intervention-cpi-for-teen-mental-health", "destination": "/resources/crisis-prevention-intervention", "statusCode": 301 },
    { "source": "/defiant-teenager-mental-health-treatment", "destination": "/resources/defiant-teenager-treatment", "statusCode": 301 },
    { "source": "/burnout-middle-high-school-students", "destination": "/resources/school-burnout-signs", "statusCode": 301 },
    { "source": "/teen-refuses-school", "destination": "/conditions/school-refusal-treatment", "statusCode": 301 },
    { "source": "/teen-bath-salts-addiction", "destination": "/conditions/substance-abuse-treatment", "statusCode": 301 },
    { "source": "/synthetic-drug-abuse-when-las-vegas-teen-rehab-becomes-critical", "destination": "/conditions/substance-abuse-treatment", "statusCode": 301 },
    { "source": "/mental-health-teen-cliques", "destination": "/conditions/anxiety-treatment", "statusCode": 301 },
    { "source": "/signs-your-teen-may-need-anxiety-and-stress-treatment", "destination": "/conditions/anxiety-treatment", "statusCode": 301 },
    { "source": "/trauma-impacts-teen-mental-health", "destination": "/conditions/trauma-ptsd-treatment", "statusCode": 301 },
    { "source": "/holistic-therapy-helps-teen-mental-health-treatment", "destination": "/programs/holistic-treatment", "statusCode": 301 },
    { "source": "/how-las-vegas-adolescent-center-guides-teens-through-crisis", "destination": "/programs/crisis-prevention-intervention", "statusCode": 301 },
    { "source": "/teen-mental-health-emotional-well-being", "destination": "/conditions", "statusCode": 301 },
    { "source": "/academic-pressure-teen-mental-health", "destination": "/resources/school-burnout-signs", "statusCode": 301 },
    { "source": "/help-teens-process-traumatic-events", "destination": "/conditions/trauma-ptsd-treatment", "statusCode": 301 },

    { "source": "/what-we-treat/:path*", "destination": "/conditions", "statusCode": 301 },
    { "source": "/blog/:path*", "destination": "/resources", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}
